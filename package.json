{
  "name": "json-ld.org",
  "private": true,
  "description": "json-ld.org homepage",
  "type": "module",
  "scripts": {
    "build": "npm run build:editor && eleventy",
    "build:editor": "esbuild playground/next/editor.mjs --bundle --outfile=_site/playground/next/editor.bundle.js",
    "pages": "wrangler pages dev _site/",
    "watch": "eleventy --watch",
    "dev": "wrangler pages dev _site --live-reload --port 8788",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@digitalbazaar/cborld": "^8.0.2",
    "cbor2": "^2.3.0",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "esbuild": "^0.27.7",
    "jsonld": "^9.0.0",
    "jsonld-vis": "github:json-ld/jsonld-vis#semver:^3.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "petite-vue": "^0.4.1",
    "wrangler": "^4.80.0",
    "yaml": "^2.8.3"
  }
